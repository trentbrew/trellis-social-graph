# Remote hosted demo — copy to .env (dev) or set in Vercel (production).
# After `pnpm run smoke:deploy`, values also live in `.trellis-db.json`.

# Client SDK origin (Sprites room node). Browser talks here directly.
NUXT_PUBLIC_TRELLIS_URL=https://your-app-name.sprites.app

# Public demo API key (CORS + Bearer). From `.trellis-db.json` after deploy.
NUXT_PUBLIC_TRELLIS_API_KEY=spk_…
